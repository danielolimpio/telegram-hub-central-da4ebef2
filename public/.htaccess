# Enable Gzip compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# Never cache HTML — prevents stale index.html referencing removed JS chunks
<IfModule mod_headers.c>
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# SPA fallback — serve root index.html for any path that does not map to
# an existing file or directory. This is required for groups (and other
# dynamic routes) created AFTER the static build, otherwise Apache returns
# 404 instead of letting the React Router handle the URL.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # ============================================================
  # SEO canonicalization — fix Google Search Console issues
  # ============================================================

  # 1) Force HTTPS + non-www (single hop) — fixes "Página com redirecionamento"
  #    for http://gruposdotelegram.org/, http://www.gruposdotelegram.org/,
  #    https://www.gruposdotelegram.org/
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://gruposdotelegram.org%{REQUEST_URI} [R=301,L,NE]

  # 2) Remove trailing slash (except root) — canonicalizes /blog/ → /blog,
  #    /grupos-telegram-cinema/ → /grupos-telegram-cinema, etc.
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule ^(.+)/$ /$1 [R=301,L]

  # 3) Legacy WordPress URLs — author archives no longer exist
  RewriteRule ^author(/.*)?$ / [R=301,L]

  # 4) Legacy /contato (and /contato?erro_grupo=...) → home
  #    The trailing "?" drops any query string from the redirect target.
  RewriteRule ^contato/?$ /? [R=301,L]

  # 5) Old /all-groups → /todos-grupos (no trailing slash, canonical form)
  RewriteRule ^all-groups/?$ /todos-grupos [R=301,L]

  # 6) Dynamic sitemap — proxy /sitemap.xml to the Supabase Edge Function
  RewriteRule ^sitemap\.xml$ https://fsfrpjsuakhkpbmqgibf.supabase.co/functions/v1/sitemap [R=302,L]

  # 7) Do not rewrite real files (JS chunks, images, etc.)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # 8) Skip asset-like requests so missing assets still 404 properly
  RewriteRule \.(js|mjs|css|map|json|xml|txt|ico|png|jpe?g|gif|webp|svg|woff2?|ttf|otf|eot|mp4|webm|pdf)$ - [L]

  # 9) Preserve known top-level app routes (don't treat them as group slugs)
  RewriteRule ^(blog|ajuda|faq|reportar|regras|seguranca|como-funciona|privacidade|termos|cookies|sitemap|todos-grupos|auth|dashboard|admin|grupo|favoritos|enviar-grupo|submit-group)(/.*)?$ - [L]
  RewriteRule ^grupos-telegram-[a-z0-9-]+$ - [L]

  # 10) Legacy root-level group slugs (WordPress-era URLs like
  #     /sobrenatural-books, /fx-trade-club, /amizades-renovadas, etc.)
  #     redirect to the new /grupo/<slug> location to preserve SEO/traffic.
  RewriteRule ^([a-z0-9][a-z0-9-]*)$ /grupo/$1 [R=301,L]

  # 11) Everything else falls back to the SPA entry point
  RewriteRule ^ /index.html [L]
</IfModule>
